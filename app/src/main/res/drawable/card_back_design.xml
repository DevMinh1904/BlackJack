<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Color -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2C3E50" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Pattern Overlay (Diamonds) -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="8dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="45">
            <shape android:shape="rectangle">
                <stroke android:width="1dp" android:color="#4A627A" />
                <solid android:color="#00000000" />
            </shape>
        </rotate>
    </item>
    <item android:top="16dp" android:left="16dp" android:right="16dp" android:bottom="16dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="45">
            <shape android:shape="rectangle">
                <stroke android:width="1dp" android:color="#4A627A" />
                <solid android:color="#00000000" />
            </shape>
        </rotate>
    </item>
</layer-list>